#!/usr/bin/env bash
set -euo pipefail

PLAYWRIGHT_DIR="/app/.playwright"

echo "-----> Installing Playwright Chromium browser to slug"
PLAYWRIGHT_BROWSERS_PATH="$PLAYWRIGHT_DIR" playwright install chromium 2>&1 || {
  echo " ! playwright install chromium failed"
  exit 1
}

echo "-----> Verifying browser binaries exist in slug"
if [ -d "$PLAYWRIGHT_DIR/chromium-"* ]; then
  echo "       Chromium found: $(ls -d $PLAYWRIGHT_DIR/chromium-*)"
else
  echo " ! Chromium binaries not found in slug!"
  exit 1
fi

echo "-----> Playwright post_compile done"
