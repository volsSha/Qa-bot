#!/usr/bin/env bash
set -euo pipefail

echo "-----> Installing system dependencies for Playwright Chromium"
apt-get update -qq 2>/dev/null
apt-get install -y --no-install-recommends \
  libatk1.0-0 \
  libatk-bridge2.0-0 \
  libcups2 \
  libdrm2 \
  libxkbcommon0 \
  libxcomposite1 \
  libxdamage1 \
  libxfixes3 \
  libxrandr2 \
  libgbm1 \
  libpango-1.0-0 \
  libcairo2 \
  libasound2t64 \
  libnspr4 \
  libnss3 \
  > /dev/null 2>&1 || {
  echo " ! apt-get install failed (non-fatal)"
}

echo "-----> Installing Playwright Chromium browser into project slug"
PLAYWRIGHT_BROWSERS_PATH="$BUILD_DIR/.playwright" playwright install chromium 2>&1 || {
  echo " ! playwright install chromium failed"
  exit 1
}

echo "-----> Verifying browser in slug"
ls "$BUILD_DIR/.playwright/" 2>&1

echo "-----> Playwright post_compile done"
