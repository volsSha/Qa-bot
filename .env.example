OPENROUTER_API_KEY=sk-or-your-key-here
LLM_MODEL=openai/gpt-4
# Provider/model format: openai/gpt-4, anthropic/claude-sonnet-4-5-20250929, openrouter/openai/gpt-4
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=7860
# Use at least 24 characters in production.
AUTH_SESSION_SECRET=replace-with-a-long-random-secret-value
AUTH_SESSION_COOKIE_NAME=qa_bot_session
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=24
AUTH_SESSION_ABSOLUTE_TTL_HOURS=168
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# Used only when no active admin exists (minimum 12 chars).
ADMIN_BOOTSTRAP_PASSWORD=change-this-bootstrap-password
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=900
AUTH_LOGIN_BLOCK_SECONDS=900
AUTH_TRUST_PROXY_HEADERS=true
PAGE_LOAD_TIMEOUT=30
MAX_PAGE_SIZE_KB=5000
RATE_LIMIT_RPM=10
MAX_CONCURRENT_SCANS=3
# SQLite local default
DATABASE_URL=sqlite+aiosqlite:///data/qa_bot.db
# LLM_API_KEY=
# LLM_API_BASE=
